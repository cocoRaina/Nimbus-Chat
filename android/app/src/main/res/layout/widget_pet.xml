<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_pet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_period_bg"
    android:padding="8dp"
    android:gravity="center">

    <FrameLayout
        android:layout_width="62dp"
        android:layout_height="62dp">

        <!-- Awake: idle-living crab loop. -->
        <ViewFlipper
            android:id="@+id/widget_pet_awake"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:autoStart="true"
            android:flipInterval="130"
            android:measureAllChildren="true">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_0" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_1" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_2" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_3" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_4" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_5" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_6" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_idle_7" android:contentDescription="@null" />
        </ViewFlipper>

        <!-- Asleep: shown at night. -->
        <ViewFlipper
            android:id="@+id/widget_pet_asleep"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:autoStart="true"
            android:flipInterval="220"
            android:visibility="gone"
            android:measureAllChildren="true">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_0" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_1" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_2" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_3" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_4" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_5" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_6" android:contentDescription="@null" />
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/crab_sleep_7" android:contentDescription="@null" />
        </ViewFlipper>
    </FrameLayout>

    <TextView
        android:id="@+id/widget_pet_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="…"
        android:textColor="#C2185B"
        android:textSize="12sp"
        android:gravity="center"
        android:maxLines="1" />
</LinearLayout>
