<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share sheet: other apps can send text/URLs to Nimbus.
                 The shared content lands in the chat composer as a draft
                 so Claude can read and respond to it. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Local notifications: exact alarms so the proactive message fires
         at the time Claude chose, not "sometime in the next 30 minutes". -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Re-schedule notifications after phone reboot (otherwise a restart
         wipes all pending local notifications). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Wake the screen to show the notification. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Android 13+ requires explicit notification permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera: the 拍照 button in the chat composer fires an HTML
         <input capture="environment"> which the Android WebView routes
         through ACTION_IMAGE_CAPTURE. Without this declaration the
         intent silently falls back to gallery-only and the button does
         nothing useful. Hardware feature is required=false so the app
         still installs on cameraless devices (rare but possible — like
         tablets). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />


    <!-- Haptics: VIBRATE is normal-protection (auto-granted) but
         declared so the Capacitor plugin's runtime check doesn't warn,
         and so future migration to USE_VIBRATE_PERMISSION (Android 13+)
         is a one-line change. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Health Connect read-only access (Android 14+ native, older
         versions via the Health Connect app). We never write back. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />

    <!-- Optional usage-stats permission for the get_device_state tool's
         daily screen-time field. Declared with tools:ignore because
         this is a special "AppOps" permission that the system reports
         as non-standard, but Android only honours it after the user
         flips the toggle in Settings → 应用使用情况. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Lets PackageManager.getApplicationLabel() resolve the display
         name (e.g. "微信" / "B站") for every other package on device.
         Without this Android 11+ hides packages from us and the
         usage-stats list falls back to bare com.* package names. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Lets us discover whether the Health Connect app is installed on
         Android <14 and lets Health Connect deep-link our privacy
         rationale screen. -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
</manifest>
